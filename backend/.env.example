# ─── Database ────────────────────────────────────────────────────────────────
# Em local: postgresql://postgres:senha@localhost:5432/contas_do_mes
# No Railway: usa ${{ Postgres.DATABASE_URL }} (variável de referência)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/contas_do_mes

# ─── JWT ──────────────────────────────────────────────────────────────────────
# IMPORTANTE: gere uma chave forte em produção (use: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=mude-esta-chave-secreta-em-producao
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# ─── Anthropic Claude (Tuco AI) ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Cloudinary (comprovantes de pagamento) ─────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── WhatsApp via Twilio ─────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─── Stripe (planos pagos) ───────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_MONTHLY_PRICE_ID=price_...
STRIPE_PRO_ANNUAL_PRICE_ID=price_...

# ─── Resend (emails) ─────────────────────────────────────────────────────────
RESEND_API_KEY=
RESEND_FROM_EMAIL=Tuco <tuco@contasdomes.com.br>

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ─── App ─────────────────────────────────────────────────────────────────────
APP_NAME=Contas do Mês
FRONTEND_URL=https://contasdomes.com.br
ALLOWED_ORIGINS=https://contasdomes.com.br,https://www.contasdomes.com.br
DEBUG=false

# Porta — Railway define automaticamente
# PORT=8000
